{
  "manifest_version": 3,
  "name": "CIPWE - Can AI Find Your Website?",
  "version": "1.0.0",
  "description": "ChatGPT, Perplexity & Google AI pull answers from websites. Check if yours shows up - one click, instant score, actionable fixes.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  }
}